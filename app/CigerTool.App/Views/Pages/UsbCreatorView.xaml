<UserControl x:Class="CigerTool.App.Views.Pages.UsbCreatorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:CigerTool.App.Behaviors">
  <ScrollViewer VerticalScrollBarVisibility="Auto"
                behaviors:SmoothScrollBehavior.IsEnabled="True">
    <StackPanel Margin="18">
      <Border Style="{StaticResource CardBorderStyle}" Background="{StaticResource AccentPanelBrush}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel>
            <TextBlock FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource ContentHeadingBrush}"
                       Text="CigerTool OS USB" />
            <TextBlock Margin="0,10,0,0"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource ContentTextBrush}"
                       Text="CigerTool OS sürümünü otomatik sorgulayın, doğrulayın ve tek akışta hedef USB'ye yazın." />
            <TextBlock Margin="0,12,0,0"
                       Foreground="{StaticResource ContentMutedTextBrush}"
                       Text="{Binding StatusMessage}" />
          </StackPanel>

          <Button Grid.Column="1"
                  Width="150"
                  Height="42"
                  Margin="16,0,0,0"
                  VerticalAlignment="Top"
                  Command="{Binding RefreshReleaseCommand}"
                  Content="Sürümü yenile"
                  Style="{StaticResource SecondaryActionButtonStyle}" />

          <Button Grid.Column="2"
                  Width="120"
                  Height="42"
                  Margin="12,0,0,0"
                  VerticalAlignment="Top"
                  Command="{Binding RefreshDevicesCommand}"
                  Content="USB tara"
                  Style="{StaticResource PrimaryActionButtonStyle}" />
        </Grid>
      </Border>

      <ItemsControl ItemsSource="{Binding Snapshot.Metrics}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Width="260" Style="{StaticResource CardBorderStyle}">
              <StackPanel>
                <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="{Binding Label}" />
                <TextBlock Margin="0,8,0,0"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource ContentHeadingBrush}"
                           Text="{Binding Value}" />
                <TextBlock Margin="0,10,0,0"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource ContentTextBrush}"
                           Text="{Binding SupportingText}" />
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <Border Style="{StaticResource CardBorderStyle}">
        <StackPanel>
          <TextBlock FontSize="18"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource ContentHeadingBrush}"
                     Text="1. CigerTool OS kaynağı" />

          <Border Margin="0,16,0,0"
                  Padding="18"
                  CornerRadius="18"
                  Background="{StaticResource SubtlePanelBrush}"
                  BorderBrush="{StaticResource CardBorderBrush}"
                  BorderThickness="1">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <StackPanel Margin="0,0,14,0">
                <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="Kaynak türü" />
                <TextBlock Margin="0,6,0,0"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource ContentHeadingBrush}"
                           Text="{Binding Snapshot.Release.ModeLabel}" />
                <TextBlock Margin="0,10,0,0"
                           Foreground="{StaticResource ContentMutedTextBrush}"
                           Text="Sürüm" />
                <TextBlock Margin="0,6,0,0"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource ContentHeadingBrush}"
                           Text="{Binding Snapshot.Release.Version}" />
                <TextBlock Margin="0,10,0,0"
                           Foreground="{StaticResource ContentMutedTextBrush}"
                           Text="İmaj" />
                <TextBlock Margin="0,6,0,0"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource ContentHeadingBrush}"
                           Text="{Binding Snapshot.Release.ImageName}" />
              </StackPanel>

              <StackPanel Grid.Column="1">
                <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="Durum" />
                <TextBlock Margin="0,6,0,0"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource ContentHeadingBrush}"
                           Text="{Binding SourceStatusLabel}" />
                <TextBlock Margin="0,10,0,0"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource ContentTextBrush}"
                           Text="{Binding SourceStatusMessage}" />
                <TextBlock Margin="0,10,0,0"
                           Foreground="{StaticResource ContentMutedTextBrush}"
                           Text="Bütünlük" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="{StaticResource ContentHeadingBrush}"
                           Text="{Binding Snapshot.Release.ChecksumStatus}" />
              </StackPanel>
            </Grid>
          </Border>

          <WrapPanel Margin="0,16,0,0">
            <Button Width="210"
                    Height="44"
                    Margin="0,0,12,12"
                    Command="{Binding DownloadAndWriteCommand}"
                    Content="Otomatik indir ve yaz"
                    Style="{StaticResource PrimaryActionButtonStyle}" />

            <Button Width="140"
                    Height="44"
                    Margin="0,0,12,12"
                    Command="{Binding DownloadOnlyCommand}"
                    Content="Sadece indir"
                    Style="{StaticResource SecondaryActionButtonStyle}" />

            <Button Width="220"
                    Height="44"
                    Margin="0,0,12,12"
                    Command="{Binding BrowseManualImageCommand}"
                    Content="Yerel CigerTool OS imajı seç"
                    Style="{StaticResource SecondaryActionButtonStyle}" />
          </WrapPanel>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource CardBorderStyle}" Background="{StaticResource RaisedSurfaceBrush}">
        <StackPanel>
          <TextBlock FontSize="18"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource ContentHeadingBrush}"
                     Text="2. Hedef USB aygıtı" />
          <TextBlock Margin="0,10,0,0"
                     TextWrapping="Wrap"
                     Foreground="{StaticResource ContentTextBrush}"
                     Text="{Binding UsbDiscoveryHint}" />

          <ListBox Margin="0,16,0,0"
                   MaxHeight="260"
                   ItemsSource="{Binding Snapshot.Devices}"
                   SelectedItem="{Binding SelectedDevice}"
                   ItemTemplate="{StaticResource UsbDeviceComboItemTemplate}" />

          <Border Margin="0,16,0,0"
                  Padding="16"
                  CornerRadius="18"
                  Background="{StaticResource SubtlePanelBrush}"
                  BorderBrush="{StaticResource CardBorderBrush}"
                  BorderThickness="1">
            <StackPanel>
              <TextBlock FontSize="16"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource ContentHeadingBrush}"
                         Text="{Binding SelectedDeviceTitle}" />
              <TextBlock Margin="0,8,0,0"
                         TextWrapping="Wrap"
                         Foreground="{StaticResource ContentTextBrush}"
                         Text="{Binding SelectedDeviceMessage}" />
              <TextBlock Margin="0,8,0,0"
                         TextWrapping="Wrap"
                         Foreground="{StaticResource ContentMutedTextBrush}"
                         Text="{Binding SelectedDeviceDetail}" />
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource CardBorderStyle}">
        <StackPanel>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
              <TextBlock FontSize="18"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource ContentHeadingBrush}"
                         Text="3. İşlem durumu" />
              <TextBlock Margin="0,10,0,0"
                         TextWrapping="Wrap"
                         Foreground="{StaticResource ContentTextBrush}"
                         Text="{Binding ProgressSummary}" />
            </StackPanel>

            <Button Grid.Column="1"
                    Width="120"
                    Height="42"
                    Command="{Binding CancelCurrentOperationCommand}"
                    Content="İptal et"
                    Style="{StaticResource SecondaryActionButtonStyle}" />
          </Grid>

          <ProgressBar Margin="0,16,0,0"
                       Height="18"
                       Minimum="0"
                       Maximum="100"
                       IsIndeterminate="{Binding IsProgressIndeterminate}"
                       Value="{Binding ProgressPercent, Mode=OneWay}" />
          <TextBlock Margin="0,10,0,0"
                     Foreground="{StaticResource ContentMutedTextBrush}"
                     Text="{Binding ProgressDetail}" />
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
