<UserControl x:Class="CigerTool.App.Views.Pages.UsbCreatorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="18">
      <Border Style="{StaticResource CardBorderStyle}" Background="{StaticResource AccentPanelBrush}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel>
            <TextBlock FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource ContentHeadingBrush}"
                       Text="{Binding Snapshot.Heading}" />
            <TextBlock Margin="0,10,0,0"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource ContentTextBrush}"
                       Text="Kaynak otomatik olarak sorgulanır, uygun USB hedefleri listelenir ve indirme ile yazma işlemi tek akışta tamamlanır." />
            <TextBlock Margin="0,12,0,0"
                       Foreground="{StaticResource ContentMutedTextBrush}"
                       Text="{Binding StatusMessage}" />
          </StackPanel>

          <Button Grid.Column="1"
                  Width="150"
                  Height="42"
                  Margin="16,0,0,0"
                  VerticalAlignment="Top"
                  Command="{Binding RefreshReleaseCommand}"
                  Content="Kaynağı yenile"
                  Style="{StaticResource SecondaryActionButtonStyle}" />

          <Button Grid.Column="2"
                  Width="130"
                  Height="42"
                  Margin="12,0,0,0"
                  VerticalAlignment="Top"
                  Command="{Binding RefreshDevicesCommand}"
                  Content="USB tara"
                  Style="{StaticResource PrimaryActionButtonStyle}" />
        </Grid>
      </Border>

      <ItemsControl ItemsSource="{Binding Snapshot.Metrics}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Width="270" Style="{StaticResource CardBorderStyle}">
              <StackPanel>
                <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="{Binding Label}" />
                <TextBlock Margin="0,8,0,0"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource ContentHeadingBrush}"
                           Text="{Binding Value}" />
                <TextBlock Margin="0,10,0,0"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource ContentTextBrush}"
                           Text="{Binding SupportingText}" />
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <Border Style="{StaticResource CardBorderStyle}">
        <StackPanel>
          <TextBlock FontSize="18"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource ContentHeadingBrush}"
                     Text="1. Ortam kaynağı" />

          <Grid Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="2*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Margin="0,0,18,0">
              <TextBlock FontSize="16"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource ContentHeadingBrush}"
                         Text="{Binding SourceStatusLabel}" />
              <TextBlock Margin="0,8,0,0"
                         TextWrapping="Wrap"
                         Foreground="{StaticResource ContentTextBrush}"
                         Text="{Binding SourceStatusMessage}" />
              <TextBlock Margin="0,12,0,0"
                         TextWrapping="Wrap"
                         Foreground="{StaticResource ContentMutedTextBrush}"
                         Text="{Binding Snapshot.Release.Notes}" />
            </StackPanel>

            <Border Grid.Column="1"
                    Padding="14"
                    CornerRadius="18"
                    Background="{StaticResource SubtlePanelBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1">
              <StackPanel>
                <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="Kaynak türü" />
                <TextBlock Margin="0,6,0,0"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource ContentHeadingBrush}"
                           Text="{Binding Snapshot.Release.ModeLabel}" />

                <TextBlock Margin="0,12,0,0"
                           Foreground="{StaticResource ContentMutedTextBrush}"
                           Text="Sürüm" />
                <TextBlock Margin="0,6,0,0"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource ContentHeadingBrush}"
                           Text="{Binding Snapshot.Release.Version}" />

                <TextBlock Margin="0,12,0,0"
                           Foreground="{StaticResource ContentMutedTextBrush}"
                           Text="Kaynak biçimi" />
                <TextBlock Margin="0,6,0,0"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource ContentHeadingBrush}"
                           Text="{Binding Snapshot.Release.SourceFormatLabel}" />

                <TextBlock Margin="0,12,0,0"
                           Foreground="{StaticResource ContentMutedTextBrush}"
                           Text="Önyükleme profili" />
                <TextBlock Margin="0,6,0,0"
                           TextWrapping="Wrap"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource ContentHeadingBrush}"
                           Text="{Binding Snapshot.Release.BootProfileLabel}" />

                <TextBlock Margin="0,12,0,0"
                           Foreground="{StaticResource ContentMutedTextBrush}"
                           Text="Yazma yöntemi" />
                <TextBlock Margin="0,6,0,0"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource ContentHeadingBrush}"
                           Text="{Binding Snapshot.Release.WriteModeLabel}" />

                <TextBlock Margin="0,12,0,0"
                           Foreground="{StaticResource ContentMutedTextBrush}"
                           Text="Uyumluluk" />
                <TextBlock Margin="0,6,0,0"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource ContentTextBrush}"
                           Text="{Binding Snapshot.Release.CompatibilityLabel}" />

                <TextBlock Margin="0,12,0,0"
                           Foreground="{StaticResource ContentMutedTextBrush}"
                           Text="İmaj" />
                <TextBlock Margin="0,6,0,0"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource ContentHeadingBrush}"
                           Text="{Binding Snapshot.Release.ImageName}" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="{StaticResource ContentMutedTextBrush}"
                           Text="{Binding Snapshot.Release.ImageSizeLabel}" />
              </StackPanel>
            </Border>
          </Grid>

          <WrapPanel Margin="0,16,0,0">
            <Button Width="210"
                    Height="44"
                    Margin="0,0,12,12"
                    Command="{Binding DownloadAndWriteCommand}"
                    Content="Otomatik indir ve yaz"
                    Style="{StaticResource PrimaryActionButtonStyle}" />

            <Button Width="140"
                    Height="44"
                    Margin="0,0,12,12"
                    Command="{Binding DownloadOnlyCommand}"
                    Content="Sadece indir"
                    Style="{StaticResource SecondaryActionButtonStyle}" />

            <Button Width="160"
                    Height="44"
                    Margin="0,0,12,12"
                    Command="{Binding BrowseManualImageCommand}"
                    Content="Manuel dosya seç"
                    Style="{StaticResource SecondaryActionButtonStyle}" />

            <Button Width="180"
                    Height="44"
                    Margin="0,0,12,12"
                    Command="{Binding WritePreparedImageCommand}"
                    Content="Hazır imajı yaz"
                    Style="{StaticResource SecondaryActionButtonStyle}" />

            <Button Width="130"
                    Height="44"
                    Margin="0,0,12,12"
                    Command="{Binding ClearManualImageCommand}"
                    Content="Seçimi temizle"
                    Style="{StaticResource SecondaryActionButtonStyle}" />
          </WrapPanel>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource CardBorderStyle}" Background="{StaticResource RaisedSurfaceBrush}">
        <StackPanel>
          <TextBlock FontSize="18"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource ContentHeadingBrush}"
                     Text="2. Hedef USB aygıtı" />
          <TextBlock Margin="0,10,0,0"
                     TextWrapping="Wrap"
                     Foreground="{StaticResource ContentTextBrush}"
                     Text="{Binding UsbDiscoveryHint}" />

          <TextBlock Margin="0,12,0,0"
                     TextWrapping="Wrap"
                     Foreground="{StaticResource ContentMutedTextBrush}"
                     Text="{Binding Snapshot.Release.CompatibilityDetails}" />

          <TextBlock Margin="0,16,0,0"
                     Foreground="{StaticResource ContentMutedTextBrush}"
                     Text="{Binding Snapshot.Devices.Count, StringFormat=Bulunan USB aygıtı: {0}}" />

          <ListBox Margin="0,12,0,0"
                   MaxHeight="260"
                   ItemsSource="{Binding Snapshot.Devices}"
                   SelectedItem="{Binding SelectedDevice}"
                   ItemTemplate="{StaticResource UsbDeviceComboItemTemplate}" />

          <Border Margin="0,16,0,0"
                  Padding="16"
                  CornerRadius="18"
                  Background="{StaticResource SubtlePanelBrush}"
                  BorderBrush="{StaticResource CardBorderBrush}"
                  BorderThickness="1">
            <StackPanel>
              <TextBlock FontSize="16"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource ContentHeadingBrush}"
                         Text="{Binding SelectedDeviceTitle}" />
              <TextBlock Margin="0,8,0,0"
                         TextWrapping="Wrap"
                         Foreground="{StaticResource ContentTextBrush}"
                         Text="{Binding SelectedDeviceMessage}" />
              <TextBlock Margin="0,8,0,0"
                         TextWrapping="Wrap"
                         Foreground="{StaticResource ContentMutedTextBrush}"
                         Text="{Binding SelectedDeviceDetail}" />
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource CardBorderStyle}">
        <StackPanel>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
              <TextBlock FontSize="18"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource ContentHeadingBrush}"
                         Text="3. İşlem durumu" />
              <TextBlock Margin="0,10,0,0"
                         TextWrapping="Wrap"
                         Foreground="{StaticResource ContentTextBrush}"
                         Text="{Binding ProgressSummary}" />
            </StackPanel>

            <Button Grid.Column="1"
                    Width="120"
                    Height="42"
                    Command="{Binding CancelCurrentOperationCommand}"
                    Content="İptal et"
                    Style="{StaticResource SecondaryActionButtonStyle}" />
          </Grid>

          <ProgressBar Margin="0,16,0,0"
                       Height="14"
                       Minimum="0"
                       Maximum="100"
                       IsIndeterminate="{Binding IsProgressIndeterminate}"
                       Value="{Binding ProgressPercent, Mode=OneWay}" />
          <TextBlock Margin="0,10,0,0"
                     Foreground="{StaticResource ContentMutedTextBrush}"
                     Text="{Binding ProgressDetail}" />
          <TextBlock Margin="0,8,0,0"
                     TextWrapping="Wrap"
                     Foreground="{StaticResource ContentMutedTextBrush}"
                     Text="{Binding CurrentOperationProgress.CurrentItem, TargetNullValue=İndirilen veya doğrulanan öğe bilgisi burada gösterilir.}" />
        </StackPanel>
      </Border>

      <Expander Margin="0,8,0,14"
                Background="{StaticResource RaisedSurfaceBrush}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                Padding="16"
                Header="Teknik ayrıntılar"
                IsExpanded="False">
        <StackPanel Margin="0,12,0,0">
          <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="Kaynak açıklaması" />
          <TextBlock Margin="0,6,0,0"
                     TextWrapping="Wrap"
                     Foreground="{StaticResource ContentTextBrush}"
                     Text="{Binding Snapshot.Release.SourceDescription}" />

          <TextBlock Margin="0,12,0,0"
                     Foreground="{StaticResource ContentMutedTextBrush}"
                     Text="İndirme adresi" />
          <TextBlock Margin="0,6,0,0"
                     TextWrapping="Wrap"
                     Foreground="{StaticResource ContentTextBrush}"
                     Text="{Binding Snapshot.Release.ImageUrl, TargetNullValue=Bu kaynakta doğrudan indirme adresi kullanılmıyor.}" />

          <TextBlock Margin="0,12,0,0"
                     Foreground="{StaticResource ContentMutedTextBrush}"
                     Text="Hazır imaj yolu" />
          <TextBlock Margin="0,6,0,0"
                     TextWrapping="Wrap"
                     Foreground="{StaticResource ContentTextBrush}"
                     Text="{Binding Snapshot.Release.PreparedImagePath, TargetNullValue=Henüz yerel imaj yolu yok.}" />

          <TextBlock Margin="0,12,0,0"
                     Foreground="{StaticResource ContentMutedTextBrush}"
                     Text="Beklenen SHA-256" />
          <TextBlock Margin="0,6,0,0"
                     TextWrapping="Wrap"
                     Foreground="{StaticResource ContentTextBrush}"
                     Text="{Binding Snapshot.Release.ExpectedSha256, TargetNullValue=Beklenen SHA-256 bilgisi yok.}" />

          <TextBlock Margin="0,12,0,0"
                     Foreground="{StaticResource ContentMutedTextBrush}"
                     Text="Hesaplanan SHA-256" />
          <TextBlock Margin="0,6,0,0"
                     TextWrapping="Wrap"
                     Foreground="{StaticResource ContentTextBrush}"
                     Text="{Binding Snapshot.Release.CalculatedSha256, TargetNullValue=Henüz hesaplanmadı.}" />

          <TextBlock Margin="0,12,0,0"
                     Foreground="{StaticResource ContentMutedTextBrush}"
                     Text="Bütünlük durumu" />
          <TextBlock Margin="0,6,0,0"
                     TextWrapping="Wrap"
                     Foreground="{StaticResource ContentHeadingBrush}"
                     Text="{Binding Snapshot.Release.ChecksumStatus}" />

          <TextBlock Margin="0,12,0,0"
                     Foreground="{StaticResource ContentMutedTextBrush}"
                     Text="İzlenen adımlar" />
          <ItemsControl Margin="0,8,0,0"
                        ItemsSource="{Binding Snapshot.Requirements}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <TextBlock Margin="0,0,0,8"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource ContentTextBrush}"
                           Text="{Binding}" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Expander>
    </StackPanel>
  </ScrollViewer>
</UserControl>
