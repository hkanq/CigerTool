<UserControl x:Class="CigerTool.App.Views.Pages.DisksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:CigerTool.App.Behaviors">
  <ScrollViewer VerticalScrollBarVisibility="Auto"
                behaviors:SmoothScrollBehavior.IsEnabled="True">
    <StackPanel Margin="18">
      <Border Style="{StaticResource CardBorderStyle}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel>
            <TextBlock FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource ContentHeadingBrush}"
                       Text="{Binding Snapshot.Heading}" />
            <TextBlock Margin="0,10,0,0"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource ContentTextBrush}"
                       Text="{Binding Snapshot.Summary}" />
            <TextBlock Margin="0,12,0,0"
                       Foreground="{StaticResource ContentMutedTextBrush}"
                       Text="{Binding StatusMessage}" />
          </StackPanel>

          <Button Grid.Column="1"
                  Width="120"
                  Height="42"
                  VerticalAlignment="Top"
                  Command="{Binding RefreshCommand}"
                  Content="Yenile"
                  Style="{StaticResource SecondaryActionButtonStyle}" />
        </Grid>
      </Border>

      <ItemsControl ItemsSource="{Binding Snapshot.Metrics}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Width="250" Style="{StaticResource CardBorderStyle}">
              <StackPanel>
                <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="{Binding Label}" />
                <TextBlock Margin="0,8,0,0"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource ContentHeadingBrush}"
                           Text="{Binding Value}" />
                <TextBlock Margin="0,10,0,0"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource ContentTextBrush}"
                           Text="{Binding SupportingText}" />
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="1.2*" />
          <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource CardBorderStyle}" Background="{StaticResource RaisedSurfaceBrush}">
          <StackPanel>
            <TextBlock FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource ContentHeadingBrush}"
                       Text="Seçili disk özeti" />
            <TextBlock Margin="0,14,0,0"
                       Foreground="{StaticResource ContentMutedTextBrush}"
                       Text="Sürücü" />
            <ComboBox Margin="0,8,0,0"
                      ItemsSource="{Binding Snapshot.Disks}"
                      SelectedItem="{Binding SelectedBenchmarkDisk}"
                      ItemTemplate="{StaticResource DiskComboItemTemplate}" />

            <Border Margin="0,16,0,0"
                    Padding="18"
                    CornerRadius="18"
                    Background="{StaticResource SubtlePanelBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1">
              <StackPanel>
                <DockPanel>
                  <StackPanel DockPanel.Dock="Left">
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ContentHeadingBrush}"
                               Text="{Binding SelectedBenchmarkDisk.Name, TargetNullValue=Sürücü seçin}" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource ContentMutedTextBrush}"
                               Text="{Binding SelectedBenchmarkDisk.DeviceModel, TargetNullValue=-}" />
                  </StackPanel>
                  <Border DockPanel.Dock="Right"
                          Padding="10,6"
                          CornerRadius="12"
                          Background="{StaticResource AccentSoftBrush}">
                    <TextBlock Foreground="{StaticResource AccentBrush}"
                               Text="{Binding SelectedBenchmarkDisk.HealthLabel, TargetNullValue=-}" />
                  </Border>
                </DockPanel>

                <Grid Margin="0,16,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>

                  <StackPanel>
                    <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="Sağlık puanı" />
                    <TextBlock Margin="0,6,0,0"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ContentHeadingBrush}"
                               Text="{Binding SelectedBenchmarkDisk.HealthScoreLabel, TargetNullValue=-}" />
                  </StackPanel>

                  <StackPanel Grid.Column="1">
                    <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="Sıcaklık" />
                    <TextBlock Margin="0,6,0,0"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ContentHeadingBrush}"
                               Text="{Binding SelectedBenchmarkDisk.TemperatureLabel, TargetNullValue=-}" />
                  </StackPanel>

                  <StackPanel Grid.Column="2">
                    <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="Tür" />
                    <TextBlock Margin="0,6,0,0"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ContentHeadingBrush}"
                               Text="{Binding SelectedBenchmarkDisk.MediaType, TargetNullValue=-}" />
                  </StackPanel>
                </Grid>

                <ItemsControl Margin="0,16,0,0"
                              ItemsSource="{Binding SelectedBenchmarkDisk.HealthHighlights}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Margin="0,0,0,8"
                                 TextWrapping="Wrap"
                                 Foreground="{StaticResource ContentTextBrush}"
                                 Text="{Binding}" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
          <StackPanel>
            <TextBlock FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource ContentHeadingBrush}"
                       Text="Benchmark" />
            <TextBlock Margin="0,10,0,0"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource ContentTextBrush}"
                       Text="CrystalDiskMark benzeri görünümle sıralı ve 4K Q1T1 sonuçlarını alın." />

            <ComboBox Margin="0,16,0,0"
                      ItemsSource="{Binding BenchmarkProfiles}"
                      SelectedItem="{Binding SelectedBenchmarkProfile}"
                      ItemTemplate="{StaticResource TitleDescriptionComboItemTemplate}" />

            <StackPanel Margin="0,16,0,0" Orientation="Horizontal">
              <Button Width="170"
                      Height="44"
                      Command="{Binding StartBenchmarkCommand}"
                      Content="Testi başlat"
                      Style="{StaticResource PrimaryActionButtonStyle}" />
              <Button Width="110"
                      Height="44"
                      Margin="12,0,0,0"
                      Command="{Binding CancelBenchmarkCommand}"
                      Content="İptal et"
                      Style="{StaticResource SecondaryActionButtonStyle}" />
            </StackPanel>

            <ProgressBar Margin="0,16,0,0"
                         Height="18"
                         Minimum="0"
                         Maximum="100"
                         Value="{Binding BenchmarkProgressPercent, Mode=OneWay}" />
            <TextBlock Margin="0,10,0,0"
                       Foreground="{StaticResource ContentMutedTextBrush}"
                       Text="{Binding BenchmarkProgressSummary}" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="{StaticResource ContentMutedTextBrush}"
                       Text="{Binding BenchmarkProgressDetail}" />

            <UniformGrid Margin="0,18,0,0" Columns="2">
              <Border Margin="0,0,10,10" Padding="14" CornerRadius="18" Background="{StaticResource SubtlePanelBrush}">
                <StackPanel>
                  <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="SEQ1M Q1T1 Read" />
                  <TextBlock Margin="0,10,0,0" FontSize="26" FontWeight="Bold" Foreground="{StaticResource ContentHeadingBrush}" Text="{Binding LastBenchmarkResult.SequentialReadLabel, TargetNullValue=-}" />
                </StackPanel>
              </Border>
              <Border Margin="0,0,0,10" Padding="14" CornerRadius="18" Background="{StaticResource SubtlePanelBrush}">
                <StackPanel>
                  <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="SEQ1M Q1T1 Write" />
                  <TextBlock Margin="0,10,0,0" FontSize="26" FontWeight="Bold" Foreground="{StaticResource ContentHeadingBrush}" Text="{Binding LastBenchmarkResult.SequentialWriteLabel, TargetNullValue=-}" />
                </StackPanel>
              </Border>
              <Border Margin="0,0,10,0" Padding="14" CornerRadius="18" Background="{StaticResource SubtlePanelBrush}">
                <StackPanel>
                  <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="RND4K Q1T1 Read" />
                  <TextBlock Margin="0,10,0,0" FontSize="26" FontWeight="Bold" Foreground="{StaticResource ContentHeadingBrush}" Text="{Binding LastBenchmarkResult.RandomReadLabel, TargetNullValue=-}" />
                  <TextBlock Margin="0,6,0,0" Foreground="{StaticResource ContentMutedTextBrush}" Text="{Binding LastBenchmarkResult.RandomReadIopsLabel, TargetNullValue=-}" />
                </StackPanel>
              </Border>
              <Border Margin="0,0,0,0" Padding="14" CornerRadius="18" Background="{StaticResource SubtlePanelBrush}">
                <StackPanel>
                  <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="RND4K Q1T1 Write" />
                  <TextBlock Margin="0,10,0,0" FontSize="26" FontWeight="Bold" Foreground="{StaticResource ContentHeadingBrush}" Text="{Binding LastBenchmarkResult.RandomWriteLabel, TargetNullValue=-}" />
                  <TextBlock Margin="0,6,0,0" Foreground="{StaticResource ContentMutedTextBrush}" Text="{Binding LastBenchmarkResult.RandomWriteIopsLabel, TargetNullValue=-}" />
                </StackPanel>
              </Border>
            </UniformGrid>

            <TextBlock Margin="0,16,0,0"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource ContentTextBrush}"
                       Text="{Binding LastBenchmarkResult.Summary, TargetNullValue=Henüz test sonucu yok.}" />
          </StackPanel>
        </Border>
      </Grid>

      <Border Style="{StaticResource CardBorderStyle}" Background="{StaticResource RaisedSurfaceBrush}">
        <StackPanel>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
              <TextBlock FontSize="18"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource ContentHeadingBrush}"
                         Text="HDD yüzey taraması" />
              <TextBlock Margin="0,10,0,0"
                         TextWrapping="Wrap"
                         Foreground="{StaticResource ContentTextBrush}"
                         Text="{Binding SurfaceScanHint}" />
            </StackPanel>

            <Button Grid.Column="1"
                    Width="180"
                    Height="44"
                    Margin="12,0,0,0"
                    Command="{Binding StartSurfaceScanCommand}"
                    Content="Yüzey taramasını başlat"
                    Style="{StaticResource PrimaryActionButtonStyle}" />

            <Button Grid.Column="2"
                    Width="110"
                    Height="44"
                    Margin="12,0,0,0"
                    Command="{Binding CancelSurfaceScanCommand}"
                    Content="İptal et"
                    Style="{StaticResource SecondaryActionButtonStyle}" />
          </Grid>

          <ProgressBar Margin="0,16,0,0"
                       Height="18"
                       Minimum="0"
                       Maximum="100"
                       Value="{Binding SurfaceScanProgressPercent, Mode=OneWay}" />
          <TextBlock Margin="0,10,0,0"
                     Foreground="{StaticResource ContentHeadingBrush}"
                     Text="{Binding SurfaceScanProgressSummary}" />
          <TextBlock Margin="0,6,0,0"
                     Foreground="{StaticResource ContentMutedTextBrush}"
                     Text="{Binding SurfaceScanProgressDetail}" />

          <Border Margin="0,16,0,0"
                  Padding="16"
                  CornerRadius="18"
                  Background="{StaticResource SubtlePanelBrush}"
                  BorderBrush="{StaticResource CardBorderBrush}"
                  BorderThickness="1">
            <StackPanel>
              <TextBlock FontWeight="SemiBold"
                         Foreground="{StaticResource ContentHeadingBrush}"
                         Text="{Binding LastSurfaceScanResult.StatusLabel, TargetNullValue=Henüz tarama sonucu yok}" />
              <TextBlock Margin="0,8,0,0"
                         TextWrapping="Wrap"
                         Foreground="{StaticResource ContentTextBrush}"
                         Text="{Binding LastSurfaceScanResult.Summary, TargetNullValue=Seçilen HDD üzerinde tarama tamamlandığında sonuç burada görünür.}" />
              <TextBlock Margin="0,8,0,0"
                         Foreground="{StaticResource ContentMutedTextBrush}"
                         Text="{Binding LastSurfaceScanResult.ScannedBytesLabel, TargetNullValue=-}" />
              <TextBlock Margin="0,4,0,0"
                         Foreground="{StaticResource ContentMutedTextBrush}"
                         Text="{Binding LastSurfaceScanResult.BadRangeCountLabel, TargetNullValue=-}" />

              <ItemsControl Margin="0,12,0,0"
                            ItemsSource="{Binding LastSurfaceScanResult.Findings}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Margin="0,0,0,8"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource ContentTextBrush}"
                               Text="{Binding}" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>

      <TextBlock Margin="0,10,0,16"
                 FontSize="18"
                 FontWeight="SemiBold"
                 Foreground="{StaticResource ContentHeadingBrush}"
                 Text="Bağlı diskler" />

      <ItemsControl ItemsSource="{Binding Snapshot.Disks}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Style="{StaticResource CardBorderStyle}">
              <StackPanel>
                <DockPanel>
                  <StackPanel DockPanel.Dock="Left">
                    <TextBlock FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ContentHeadingBrush}"
                               Text="{Binding Name}" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource ContentMutedTextBrush}"
                               Text="{Binding IdentityLabel}" />
                  </StackPanel>

                  <Border DockPanel.Dock="Right"
                          Padding="12,8"
                          CornerRadius="12"
                          Background="{StaticResource AccentSoftBrush}">
                    <StackPanel>
                      <TextBlock HorizontalAlignment="Center" Foreground="{StaticResource AccentBrush}" Text="{Binding HealthLabel}" />
                      <TextBlock Margin="0,4,0,0" HorizontalAlignment="Center" Foreground="{StaticResource ContentHeadingBrush}" Text="{Binding HealthScoreLabel}" />
                    </StackPanel>
                  </Border>
                </DockPanel>

                <WrapPanel Margin="0,12,0,0">
                  <Border Margin="0,0,10,8" Padding="10,6" CornerRadius="12" Background="{StaticResource TagSurfaceBrush}">
                    <TextBlock Foreground="{StaticResource ContentHeadingBrush}" Text="{Binding MediaType}" />
                  </Border>
                  <Border Margin="0,0,10,8" Padding="10,6" CornerRadius="12" Background="{StaticResource TagSurfaceBrush}">
                    <TextBlock Foreground="{StaticResource ContentHeadingBrush}" Text="{Binding ConnectionType}" />
                  </Border>
                  <Border Margin="0,0,10,8" Padding="10,6" CornerRadius="12" Background="{StaticResource TagSurfaceBrush}">
                    <TextBlock Foreground="{StaticResource ContentHeadingBrush}" Text="{Binding TemperatureLabel}" />
                  </Border>
                </WrapPanel>

                <Grid Margin="0,12,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.4*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>

                  <StackPanel>
                    <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="Marka / model" />
                    <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Foreground="{StaticResource ContentHeadingBrush}" Text="{Binding DeviceModel}" />
                  </StackPanel>
                  <StackPanel Grid.Column="1">
                    <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="Toplam" />
                    <TextBlock Margin="0,4,0,0" Foreground="{StaticResource ContentHeadingBrush}" Text="{Binding CapacityLabel}" />
                  </StackPanel>
                  <StackPanel Grid.Column="2">
                    <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="Boş" />
                    <TextBlock Margin="0,4,0,0" Foreground="{StaticResource ContentHeadingBrush}" Text="{Binding FreeLabel}" />
                  </StackPanel>
                  <StackPanel Grid.Column="3">
                    <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="Seri no" />
                    <TextBlock Margin="0,4,0,0" Foreground="{StaticResource ContentHeadingBrush}" Text="{Binding SerialNumber}" />
                  </StackPanel>
                </Grid>

                <ProgressBar Margin="0,14,0,0"
                             Height="18"
                             Minimum="0"
                             Maximum="100"
                             Value="{Binding UsagePercent}" />

                <TextBlock Margin="0,10,0,0"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource ContentTextBrush}"
                           Text="{Binding WarningSummary}" />

                <Expander Margin="0,16,0,0"
                          Background="{StaticResource RaisedSurfaceBrush}"
                          BorderBrush="{StaticResource CardBorderBrush}"
                          BorderThickness="1"
                          Padding="14"
                          Header="Sağlık ayrıntıları"
                          IsExpanded="False">
                  <StackPanel Margin="0,12,0,0">
                    <ItemsControl ItemsSource="{Binding HealthDetails}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="180" />
                              <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="{Binding Label}" />
                            <TextBlock Grid.Column="1" TextWrapping="Wrap" Foreground="{StaticResource ContentHeadingBrush}" Text="{Binding Value}" />
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Margin="0,12,0,0"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ContentHeadingBrush}"
                               Text="SMART öznitelikleri" />

                    <ItemsControl Margin="0,10,0,0" ItemsSource="{Binding SmartAttributes}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Margin="0,0,0,8"
                                  Padding="12"
                                  CornerRadius="14"
                                  Background="{StaticResource SubtlePanelBrush}"
                                  BorderBrush="{StaticResource CardBorderBrush}"
                                  BorderThickness="1">
                            <Grid>
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="64" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1.2*" />
                              </Grid.ColumnDefinitions>
                              <TextBlock Foreground="{StaticResource ContentHeadingBrush}" Text="{Binding Id}" />
                              <TextBlock Grid.Column="1" Foreground="{StaticResource ContentHeadingBrush}" Text="{Binding Name}" />
                              <TextBlock Grid.Column="2" Foreground="{StaticResource ContentTextBrush}" Text="{Binding CurrentValue}" />
                              <TextBlock Grid.Column="3" Foreground="{StaticResource ContentTextBrush}" Text="{Binding WorstValue}" />
                              <TextBlock Grid.Column="4" Foreground="{StaticResource ContentTextBrush}" Text="{Binding ThresholdValue}" />
                              <StackPanel Grid.Column="5">
                                <TextBlock Foreground="{StaticResource ContentHeadingBrush}" Text="{Binding RawValue}" />
                                <TextBlock Margin="0,4,0,0" Foreground="{StaticResource ContentMutedTextBrush}" Text="{Binding StatusLabel}" />
                              </StackPanel>
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Expander>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </ScrollViewer>
</UserControl>
