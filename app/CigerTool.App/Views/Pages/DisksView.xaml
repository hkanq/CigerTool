<UserControl x:Class="CigerTool.App.Views.Pages.DisksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="18">
      <Border Style="{StaticResource CardBorderStyle}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel>
            <TextBlock FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource ContentHeadingBrush}"
                       Text="{Binding Snapshot.Heading}" />
            <TextBlock Margin="0,10,0,0"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource ContentTextBrush}"
                       Text="{Binding Snapshot.Summary}" />
            <TextBlock Margin="0,12,0,0"
                       Foreground="{StaticResource ContentMutedTextBrush}"
                       Text="{Binding StatusMessage}" />
          </StackPanel>

          <Button Grid.Column="1"
                  Width="120"
                  Height="42"
                  VerticalAlignment="Top"
                  Command="{Binding RefreshCommand}"
                  Content="Yenile"
                  Style="{StaticResource SecondaryActionButtonStyle}" />
        </Grid>
      </Border>

      <ItemsControl ItemsSource="{Binding Snapshot.Metrics}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Width="270" Style="{StaticResource CardBorderStyle}">
              <StackPanel>
                <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="{Binding Label}" />
                <TextBlock Margin="0,8,0,0"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource ContentHeadingBrush}"
                           Text="{Binding Value}" />
                <TextBlock Margin="0,10,0,0"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource ContentTextBrush}"
                           Text="{Binding SupportingText}" />
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <Border Style="{StaticResource CardBorderStyle}" Background="{StaticResource RaisedSurfaceBrush}">
        <StackPanel>
          <TextBlock FontSize="18"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource ContentHeadingBrush}"
                     Text="Sağlık ve performans testi" />
          <TextBlock Margin="0,10,0,0"
                     TextWrapping="Wrap"
                     Foreground="{StaticResource ContentTextBrush}"
                     Text="Seçilen sürücü için sağlık özetini inceleyebilir, sıralı okuma-yazma ve 4K rastgele testleri çalıştırabilirsiniz." />

          <Grid Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="2*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Margin="0,0,12,0">
              <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="Sürücü" />
              <ComboBox Margin="0,8,0,0"
                        ItemsSource="{Binding Snapshot.Disks}"
                        SelectedItem="{Binding SelectedBenchmarkDisk}"
                        ItemTemplate="{StaticResource DiskComboItemTemplate}" />
            </StackPanel>

            <StackPanel Grid.Column="1">
              <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="Test profili" />
              <ComboBox Margin="0,8,0,0"
                        ItemsSource="{Binding BenchmarkProfiles}"
                        SelectedItem="{Binding SelectedBenchmarkProfile}"
                        ItemTemplate="{StaticResource TitleDescriptionComboItemTemplate}" />
            </StackPanel>
          </Grid>

          <StackPanel Margin="0,14,0,0" Orientation="Horizontal">
            <Button Width="190"
                    Height="44"
                    Command="{Binding StartBenchmarkCommand}"
                    Content="Performans testini başlat"
                    Style="{StaticResource PrimaryActionButtonStyle}" />
            <Button Width="120"
                    Height="44"
                    Margin="12,0,0,0"
                    Command="{Binding CancelBenchmarkCommand}"
                    Content="İptal et"
                    Style="{StaticResource SecondaryActionButtonStyle}" />
          </StackPanel>

          <TextBlock Margin="0,14,0,0"
                     TextWrapping="Wrap"
                     Foreground="{StaticResource ContentMutedTextBrush}"
                     Text="{Binding BenchmarkProgressSummary}" />
          <ProgressBar Margin="0,10,0,0"
                       Height="14"
                       Minimum="0"
                       Maximum="100"
                       Value="{Binding BenchmarkProgressPercent, Mode=OneWay}" />
          <TextBlock Margin="0,8,0,0"
                     Foreground="{StaticResource ContentMutedTextBrush}"
                     Text="{Binding BenchmarkProgressDetail}" />

          <Border Margin="0,16,0,0"
                  Padding="14"
                  CornerRadius="18"
                  Background="{StaticResource SubtlePanelBrush}"
                  BorderBrush="{StaticResource CardBorderBrush}"
                  BorderThickness="1">
            <StackPanel>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="Durum" />
                <TextBlock Grid.Column="1"
                           Foreground="{StaticResource ContentMutedTextBrush}"
                           Text="Sıralı okuma / yazma" />
                <TextBlock Grid.Column="2"
                           Foreground="{StaticResource ContentMutedTextBrush}"
                           Text="4K rastgele okuma / yazma" />

                <TextBlock Grid.Row="1"
                           Margin="0,6,0,0"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource ContentHeadingBrush}"
                           Text="{Binding LastBenchmarkResult.StatusLabel, TargetNullValue=Henüz test sonucu yok}" />
                <TextBlock Grid.Row="1"
                           Grid.Column="1"
                           Margin="0,6,0,0"
                           Foreground="{StaticResource ContentHeadingBrush}"
                           Text="{Binding LastBenchmarkResult.SequentialReadLabel, TargetNullValue=-}" />
                <TextBlock Grid.Row="1"
                           Grid.Column="2"
                           Margin="0,6,0,0"
                           Foreground="{StaticResource ContentHeadingBrush}"
                           Text="{Binding LastBenchmarkResult.RandomReadLabel, TargetNullValue=-}" />

                <TextBlock Grid.Row="2"
                           Margin="0,6,0,0"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource ContentTextBrush}"
                           Text="{Binding LastBenchmarkResult.Summary, TargetNullValue=Test tamamlandığında özet burada görünür.}" />
                <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,6,0,0">
                  <TextBlock Foreground="{StaticResource ContentTextBrush}"
                             Text="{Binding LastBenchmarkResult.SequentialWriteLabel, TargetNullValue=-}" />
                  <TextBlock Margin="0,4,0,0"
                             Foreground="{StaticResource ContentMutedTextBrush}"
                             Text="{Binding LastBenchmarkResult.TestFileSizeLabel, TargetNullValue=-}" />
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,6,0,0">
                  <TextBlock Foreground="{StaticResource ContentTextBrush}"
                             Text="{Binding LastBenchmarkResult.RandomWriteLabel, TargetNullValue=-}" />
                  <TextBlock Margin="0,4,0,0"
                             Foreground="{StaticResource ContentMutedTextBrush}"
                             Text="{Binding LastBenchmarkResult.RandomReadIopsLabel, TargetNullValue=-}" />
                  <TextBlock Margin="0,4,0,0"
                             Foreground="{StaticResource ContentMutedTextBrush}"
                             Text="{Binding LastBenchmarkResult.RandomWriteIopsLabel, TargetNullValue=-}" />
                </StackPanel>
              </Grid>

              <ItemsControl Margin="0,12,0,0"
                            ItemsSource="{Binding LastBenchmarkResult.Notes}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Margin="0,0,0,8"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource ContentMutedTextBrush}"
                               Text="{Binding}" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>

      <TextBlock Margin="0,10,0,16"
                 FontSize="18"
                 FontWeight="SemiBold"
                 Foreground="{StaticResource ContentHeadingBrush}"
                 Text="Bağlı sürücüler" />

      <ItemsControl ItemsSource="{Binding Snapshot.Disks}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Style="{StaticResource CardBorderStyle}">
              <StackPanel>
                <DockPanel>
                  <StackPanel DockPanel.Dock="Left">
                    <TextBlock FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ContentHeadingBrush}"
                               Text="{Binding Name}" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource ContentMutedTextBrush}"
                               Text="{Binding IdentityLabel}" />
                  </StackPanel>

                  <Border DockPanel.Dock="Right"
                          Padding="10,6"
                          CornerRadius="12"
                          Background="{StaticResource AccentSoftBrush}">
                    <TextBlock Foreground="{StaticResource AccentBrush}"
                               Text="{Binding HealthLabel}" />
                  </Border>
                </DockPanel>

                <WrapPanel Margin="0,12,0,0">
                  <Border Margin="0,0,10,8"
                          Padding="10,6"
                          CornerRadius="12"
                          Background="{StaticResource TagSurfaceBrush}">
                    <TextBlock Foreground="{StaticResource ContentHeadingBrush}" Text="{Binding FileSystem}" />
                  </Border>
                  <Border Margin="0,0,10,8"
                          Padding="10,6"
                          CornerRadius="12"
                          Background="{StaticResource TagSurfaceBrush}">
                    <TextBlock Foreground="{StaticResource ContentHeadingBrush}" Text="{Binding ConnectionType}" />
                  </Border>
                  <Border Margin="0,0,10,8"
                          Padding="10,6"
                          CornerRadius="12"
                          Background="{StaticResource TagSurfaceBrush}">
                    <TextBlock Foreground="{StaticResource ContentHeadingBrush}" Text="{Binding MediaType}" />
                  </Border>
                </WrapPanel>

                <Grid Margin="0,10,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.4*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>

                  <StackPanel>
                    <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="Marka / model" />
                    <TextBlock Margin="0,4,0,0"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource ContentHeadingBrush}"
                               Text="{Binding DeviceModel}" />
                  </StackPanel>

                  <StackPanel Grid.Column="1">
                    <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="Sağlık" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{StaticResource ContentHeadingBrush}"
                               Text="{Binding HealthLabel}" />
                  </StackPanel>

                  <StackPanel Grid.Column="2">
                    <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="Toplam" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{StaticResource ContentHeadingBrush}"
                               Text="{Binding CapacityLabel}" />
                  </StackPanel>

                  <StackPanel Grid.Column="3">
                    <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="Boş" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{StaticResource ContentHeadingBrush}"
                               Text="{Binding FreeLabel}" />
                  </StackPanel>
                </Grid>

                <Grid Margin="0,10,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>

                  <StackPanel>
                    <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="Kullanılan" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{StaticResource ContentHeadingBrush}"
                               Text="{Binding UsedLabel}" />
                  </StackPanel>

                  <StackPanel Grid.Column="1">
                    <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="Yerleşim" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{StaticResource ContentHeadingBrush}"
                               Text="{Binding LayoutLabel}" />
                  </StackPanel>
                </Grid>

                <ProgressBar Margin="0,12,0,0"
                             Height="12"
                             Minimum="0"
                             Maximum="100"
                             Value="{Binding UsagePercent}" />

                <TextBlock Margin="0,10,0,0"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource ContentTextBrush}"
                           Text="{Binding WarningSummary}" />
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <Expander Margin="0,8,0,14"
                Background="{StaticResource RaisedSurfaceBrush}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                Padding="16"
                Header="Gelişmiş sistem bilgileri"
                IsExpanded="False">
        <StackPanel Margin="0,12,0,0">
          <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="Bilgisayar adı" />
          <TextBlock Margin="0,4,0,0" Foreground="{StaticResource ContentHeadingBrush}" Text="{Binding Snapshot.System.MachineName}" />
          <TextBlock Margin="0,12,0,0" Foreground="{StaticResource ContentMutedTextBrush}" Text="İşletim sistemi" />
          <TextBlock Margin="0,4,0,0" Foreground="{StaticResource ContentHeadingBrush}" Text="{Binding Snapshot.System.OperatingSystem}" />
          <TextBlock Margin="0,12,0,0" Foreground="{StaticResource ContentMutedTextBrush}" Text="Mimari" />
          <TextBlock Margin="0,4,0,0" Foreground="{StaticResource ContentHeadingBrush}" Text="{Binding Snapshot.System.Architecture}" />
          <TextBlock Margin="0,12,0,0" Foreground="{StaticResource ContentMutedTextBrush}" Text=".NET çalışma zamanı" />
          <TextBlock Margin="0,4,0,0" Foreground="{StaticResource ContentHeadingBrush}" Text="{Binding Snapshot.System.Framework}" />
          <TextBlock Margin="0,12,0,0" Foreground="{StaticResource ContentMutedTextBrush}" Text="Oturum" />
          <TextBlock Margin="0,4,0,0" Foreground="{StaticResource ContentHeadingBrush}" Text="{Binding Snapshot.System.CurrentUser}" />
          <TextBlock Margin="0,12,0,0" Foreground="{StaticResource ContentMutedTextBrush}" Text="Sistem sürücüsü" />
          <TextBlock Margin="0,4,0,0" Foreground="{StaticResource ContentHeadingBrush}" Text="{Binding Snapshot.System.SystemDrive}" />
          <TextBlock Margin="0,12,0,0" Foreground="{StaticResource ContentMutedTextBrush}" Text="Açık kalma süresi" />
          <TextBlock Margin="0,4,0,0" Foreground="{StaticResource ContentHeadingBrush}" Text="{Binding Snapshot.System.UptimeLabel}" />
        </StackPanel>
      </Expander>

      <Border Style="{StaticResource CardBorderStyle}">
        <StackPanel>
          <TextBlock FontSize="18"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource ContentHeadingBrush}"
                     Text="Notlar" />
          <ItemsControl Margin="0,12,0,0"
                        ItemsSource="{Binding Snapshot.Notes}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <TextBlock Margin="0,0,0,10"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource ContentTextBrush}"
                           Text="{Binding}" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
