<UserControl x:Class="CigerTool.App.Views.Pages.ToolsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:CigerTool.App.Behaviors">
  <ScrollViewer VerticalScrollBarVisibility="Auto"
                behaviors:SmoothScrollBehavior.IsEnabled="True">
    <StackPanel Margin="18">
      <Border Style="{StaticResource CardBorderStyle}" Background="{StaticResource AccentPanelBrush}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel>
            <TextBlock FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource ContentHeadingBrush}" Text="Kurulum Medyası" />
            <TextBlock Margin="0,10,0,0" TextWrapping="Wrap" Foreground="{StaticResource ContentTextBrush}" Text="Windows, Linux, WinPE ve araç ISO'larını USB'ye yazabilir; Windows kaynaklarını doğrudan hedef diske kurabilirsiniz." />
            <TextBlock Margin="0,12,0,0" Foreground="{StaticResource ContentMutedTextBrush}" Text="{Binding StatusMessage}" />
          </StackPanel>

          <Button Grid.Column="1"
                  Width="130"
                  Height="42"
                  VerticalAlignment="Top"
                  Command="{Binding RefreshDevicesCommand}"
                  Content="Hedefleri yenile"
                  Style="{StaticResource SecondaryActionButtonStyle}" />
        </Grid>
      </Border>

      <Border Style="{StaticResource CardBorderStyle}">
        <StackPanel>
          <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource ContentHeadingBrush}" Text="1. Kaynak dosya" />
          <TextBlock Margin="0,10,0,0" TextWrapping="Wrap" Foreground="{StaticResource ContentTextBrush}" Text="ISO, WIM, ESD veya yazılabilir disk imajı seçin. Kaynak profili otomatik algılanır." />

          <WrapPanel Margin="0,16,0,0">
            <Button Width="170" Height="44" Margin="0,0,12,12" Command="{Binding BrowseImageCommand}" Content="Kaynak seç" Style="{StaticResource PrimaryActionButtonStyle}" />
            <Button Width="120" Height="44" Margin="0,0,12,12" Command="{Binding ClearImageCommand}" Content="Temizle" Style="{StaticResource SecondaryActionButtonStyle}" />
          </WrapPanel>

          <Border Margin="0,16,0,0" Padding="18" CornerRadius="18" Background="{StaticResource SubtlePanelBrush}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <StackPanel Margin="0,0,14,0">
                <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="Kaynak adı" />
                <TextBlock Margin="0,6,0,0" FontWeight="SemiBold" Foreground="{StaticResource ContentHeadingBrush}" Text="{Binding Snapshot.Release.ImageName, TargetNullValue=Henüz dosya seçilmedi.}" />
                <TextBlock Margin="0,10,0,0" Foreground="{StaticResource ContentMutedTextBrush}" Text="Önyükleme profili" />
                <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Foreground="{StaticResource ContentHeadingBrush}" Text="{Binding Snapshot.Release.BootProfileLabel}" />
                <TextBlock Margin="0,10,0,0" Foreground="{StaticResource ContentMutedTextBrush}" Text="Yöntem" />
                <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Foreground="{StaticResource ContentTextBrush}" Text="{Binding Snapshot.Release.WriteModeLabel}" />
              </StackPanel>

              <StackPanel Grid.Column="1">
                <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="Uyumluluk" />
                <TextBlock Margin="0,6,0,0" FontWeight="SemiBold" Foreground="{StaticResource ContentHeadingBrush}" Text="{Binding Snapshot.Release.CompatibilityLabel}" />
                <TextBlock Margin="0,10,0,0" TextWrapping="Wrap" Foreground="{StaticResource ContentTextBrush}" Text="{Binding Snapshot.Release.CompatibilityDetails}" />
                <TextBlock Margin="0,10,0,0" Foreground="{StaticResource ContentMutedTextBrush}" Text="İş akışı" />
                <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Foreground="{StaticResource ContentTextBrush}" Text="{Binding SourceWorkflowHint}" />
              </StackPanel>
            </Grid>
          </Border>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource CardBorderStyle}" Background="{StaticResource RaisedSurfaceBrush}">
        <StackPanel>
          <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource ContentHeadingBrush}" Text="2. İşlem türü" />
          <ComboBox Margin="0,16,0,0"
                    ItemsSource="{Binding Modes}"
                    SelectedItem="{Binding SelectedMode}"
                    ItemTemplate="{StaticResource TitleDescriptionComboItemTemplate}" />
          <TextBlock Margin="0,12,0,0" TextWrapping="Wrap" Foreground="{StaticResource ContentTextBrush}" Text="{Binding TargetHint}" />
          <Border Margin="0,14,0,0"
                  Padding="14"
                  CornerRadius="16"
                  Background="{StaticResource SubtlePanelBrush}"
                  BorderBrush="{StaticResource CardBorderBrush}"
                  BorderThickness="1">
            <TextBlock TextWrapping="Wrap"
                       Foreground="{StaticResource ContentTextBrush}"
                       Text="{Binding SourceWorkflowHint}" />
          </Border>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource CardBorderStyle}" Visibility="{Binding ShowUsbTargetSelector, Converter={StaticResource BooleanToVisibilityConverter}}">
        <StackPanel>
          <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource ContentHeadingBrush}" Text="3. Hedef USB aygıtı" />
          <ListBox Margin="0,16,0,0"
                   MaxHeight="280"
                   ItemsSource="{Binding Snapshot.Devices}"
                   SelectedItem="{Binding SelectedDevice}"
                   ItemTemplate="{StaticResource UsbDeviceComboItemTemplate}" />
          <TextBlock Margin="0,12,0,0" TextWrapping="Wrap" Foreground="{StaticResource ContentTextBrush}" Text="{Binding SelectedDeviceMessage}" />
        </StackPanel>
      </Border>

      <Border Style="{StaticResource CardBorderStyle}" Visibility="{Binding ShowDiskTargetSelector, Converter={StaticResource BooleanToVisibilityConverter}}">
        <StackPanel>
          <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource ContentHeadingBrush}" Text="3. Hedef disk" />
          <ComboBox Margin="0,16,0,0"
                    ItemsSource="{Binding DeploymentCandidates}"
                    SelectedItem="{Binding SelectedTargetDisk}"
                    ItemTemplate="{StaticResource DiskComboItemTemplate}" />
          <CheckBox Margin="0,16,0,0"
                    IsChecked="{Binding PortableModeEnabled}"
                    Content="Taşınabilir Windows düzeni uygula" />
          <ComboBox Margin="0,16,0,0"
                    Visibility="{Binding ShowEditionSelector, Converter={StaticResource BooleanToVisibilityConverter}}"
                    ItemsSource="{Binding AvailableEditions}"
                    SelectedItem="{Binding SelectedEdition}"
                    ItemTemplate="{StaticResource WindowsEditionComboItemTemplate}" />
          <TextBlock Margin="0,12,0,0" TextWrapping="Wrap" Foreground="{StaticResource ContentTextBrush}" Text="Bu işlem seçilen hedef diski temizler, yeniden bölümlendirir, Windows imajını açar ve önyükleme dosyalarını kurar." />
        </StackPanel>
      </Border>

      <Border Style="{StaticResource CardBorderStyle}">
        <StackPanel>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
              <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource ContentHeadingBrush}" Text="4. İşlem" />
              <TextBlock Margin="0,10,0,0" TextWrapping="Wrap" Foreground="{StaticResource ContentTextBrush}" Text="{Binding ProgressSummary}" />
            </StackPanel>

            <Button Grid.Column="1"
                    Width="160"
                    Height="44"
                    Margin="12,0,0,0"
                    Command="{Binding StartCommand}"
                    Content="İşlemi başlat"
                    Style="{StaticResource PrimaryActionButtonStyle}" />

            <Button Grid.Column="2"
                    Width="110"
                    Height="44"
                    Margin="12,0,0,0"
                    Command="{Binding CancelCurrentOperationCommand}"
                    Content="İptal et"
                    Style="{StaticResource SecondaryActionButtonStyle}" />
          </Grid>

          <ProgressBar Margin="0,16,0,0"
                       Height="18"
                       Minimum="0"
                       Maximum="100"
                       IsIndeterminate="{Binding IsProgressIndeterminate}"
                       Value="{Binding ProgressPercent, Mode=OneWay}" />
          <TextBlock Margin="0,10,0,0" Foreground="{StaticResource ContentMutedTextBrush}" Text="{Binding ProgressDetail}" />
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
