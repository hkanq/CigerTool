<Application x:Class="CigerTool.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:CigerTool.App.Converters"
             xmlns:appModels="clr-namespace:CigerTool.Application.Models;assembly=CigerTool.Application"
             xmlns:domainModels="clr-namespace:CigerTool.Domain.Models;assembly=CigerTool.Domain"
             xmlns:pages="clr-namespace:CigerTool.App.Views.Pages"
             xmlns:viewModels="clr-namespace:CigerTool.App.ViewModels.Pages">
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Styles/Colors.xaml" />
        <ResourceDictionary Source="Styles/Controls.xaml" />
      </ResourceDictionary.MergedDictionaries>

      <converters:BooleanToFriendlyTextConverter x:Key="BooleanToFriendlyTextConverter" />
      <converters:OperationSeverityToFriendlyTextConverter x:Key="OperationSeverityToFriendlyTextConverter" />
      <converters:CloneSuitabilityStatusToFriendlyTextConverter x:Key="CloneSuitabilityStatusToFriendlyTextConverter" />
      <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

      <DataTemplate x:Key="DiskComboItemTemplate" DataType="{x:Type domainModels:DiskSummary}">
        <Grid Margin="0,2">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <TextBlock FontSize="14"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource ContentHeadingBrush}"
                     Text="{Binding Name}" />
          <TextBlock Grid.Column="1"
                     Margin="12,0,0,0"
                     VerticalAlignment="Center"
                     Foreground="{StaticResource TagTextBrush}"
                     Text="{Binding CapacityLabel}" />

          <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,6,0,0">
            <TextBlock Foreground="{StaticResource ContentMutedTextBrush}"
                       Text="{Binding DeviceModel, TargetNullValue=Bilinmeyen model}" />
            <WrapPanel Margin="0,6,0,0">
              <Border Margin="0,0,8,0"
                      Padding="8,4"
                      Background="{StaticResource TagSurfaceBrush}"
                      CornerRadius="10">
                <TextBlock Foreground="{StaticResource TagTextBrush}" Text="{Binding MediaType}" />
              </Border>
              <Border Margin="0,0,8,0"
                      Padding="8,4"
                      Background="{StaticResource TagSurfaceBrush}"
                      CornerRadius="10">
                <TextBlock Foreground="{StaticResource TagTextBrush}" Text="{Binding HealthLabel}" />
              </Border>
              <Border Margin="0,0,8,0"
                      Padding="8,4"
                      Background="{StaticResource TagSurfaceBrush}"
                      CornerRadius="10">
                <TextBlock Foreground="{StaticResource TagTextBrush}" Text="{Binding ConnectionType}" />
              </Border>
            </WrapPanel>

            <TextBlock Margin="0,6,0,0"
                       Foreground="{StaticResource ContentMutedTextBrush}"
                       Text="{Binding WarningSummary}" />
          </StackPanel>
        </Grid>
      </DataTemplate>

      <DataTemplate x:Key="UsbDeviceComboItemTemplate" DataType="{x:Type appModels:UsbDeviceEntry}">
        <Grid Margin="0,2">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <TextBlock FontSize="14"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource ContentHeadingBrush}"
                     Text="{Binding Model}" />
          <TextBlock Grid.Column="1"
                     Margin="12,0,0,0"
                     VerticalAlignment="Center"
                     Foreground="{StaticResource TagTextBrush}"
                     Text="{Binding SizeLabel}" />

          <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,6,0,0">
            <TextBlock Foreground="{StaticResource ContentMutedTextBrush}" Text="{Binding MountedVolumesLabel}" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="{StaticResource ContentMutedTextBrush}"
                       Text="{Binding SafetyStatus}" />
          </StackPanel>
        </Grid>
      </DataTemplate>

      <DataTemplate x:Key="TitleDescriptionComboItemTemplate">
        <StackPanel Margin="0,2">
          <TextBlock FontSize="14"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource ContentHeadingBrush}"
                     Text="{Binding Title}" />
          <TextBlock Margin="0,4,0,0"
                     TextWrapping="Wrap"
                     Foreground="{StaticResource ContentMutedTextBrush}"
                     Text="{Binding Description}" />
        </StackPanel>
      </DataTemplate>

      <DataTemplate DataType="{x:Type viewModels:DashboardPageViewModel}">
        <pages:DashboardView />
      </DataTemplate>
      <DataTemplate DataType="{x:Type viewModels:CloningPageViewModel}">
        <pages:CloningView />
      </DataTemplate>
      <DataTemplate DataType="{x:Type viewModels:BackupImagePageViewModel}">
        <pages:BackupImageView />
      </DataTemplate>
      <DataTemplate DataType="{x:Type viewModels:DisksPageViewModel}">
        <pages:DisksView />
      </DataTemplate>
      <DataTemplate DataType="{x:Type viewModels:UsbCreatorPageViewModel}">
        <pages:UsbCreatorView />
      </DataTemplate>
      <DataTemplate DataType="{x:Type viewModels:LogsPageViewModel}">
        <pages:LogsView />
      </DataTemplate>
      <DataTemplate DataType="{x:Type viewModels:SettingsPageViewModel}">
        <pages:SettingsView />
      </DataTemplate>
    </ResourceDictionary>
  </Application.Resources>
</Application>
